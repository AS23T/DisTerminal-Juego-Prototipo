@page
@model pryLPWeb_DisTerminal.Pages.HistorialModel
@{
    ViewData["Title"] = "Historial de Partidas";
}

<div style="background-color: #e6e6fa; height: 100vh; padding: 20px;">

    <div style="display: flex; justify-content: space-between; font-family: monospace; font-style: italic; font-size: 24px; margin-bottom: 20px;">
        <span>[DisTerminal] Historial Global</span>
        <div>
            <a href="/Juego" style="text-decoration: none; color: black; margin-right: 20px;">Volver a la Terminal</a>
            <a href="/" style="text-decoration: none; color: black;">Cerrar Sesion</a>
        </div>
    </div>

    <div style="background-color: black; width: 80%; height: 70vh; margin: 0 auto; padding: 20px; font-family: monospace; color: #00FF00; overflow-y: auto; border: 2px solid white;">

        <h2 style="text-align: center; color: #FFFF00;">=== TOP RECORDS DE TIEMPO ===</h2>

        <table style="width: 100%; text-align: left; margin-top: 20px; border-collapse: collapse;">
            <thead>
                <tr style="border-bottom: 1px dashed #00FF00;">
                    <th style="padding: 10px;">JUGADOR</th>
                    <th style="padding: 10px;">TIEMPO DE RESOLUCIÓN</th>
                    <th style="padding: 10px;">FECHA</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Registros != null && Model.Registros.Any())
                {
                    foreach (var item in Model.Registros)
                    {
                        <tr style="border-bottom: 1px dotted #004400;">
                            <td style="padding: 10px;">@item.Jugador.NombreUsuario</td>
                            <td style="padding: 10px;">
                                
                                @item.TiempoJugado.ToString(@"hh\:mm\:ss")
                            </td>
                            <td style="padding: 10px;">@item.FechaPartida.ToString("dd/MM/yyyy HH:mm")</td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="3" style="padding: 10px; text-align: center; color: gray;">
                            No hay registros todavía. ¡Juega una partida para dejar tu marca!
                        </td>
                    </tr>
                }
            </tbody>
        </table>

    </div>
</div>