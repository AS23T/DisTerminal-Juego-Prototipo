# =====================================================
# .gitignore para Proyecto ASP.NET Core MVC con SQLite
# =====================================================

# 1. Carpetas de compilación y binarios de .NET
[Bb]in/
[Oo]bj/

# 2. Archivos de la Base de Datos SQLite (¡CRÍTICO!)
# Esto evita subir la base de datos real con los récords locales
*.db
*.db-shm
*.db-wal
TerminalDB.db

# 3. Archivos y carpetas de configuración de Visual Studio
.vs/
*.user
*.userosscache
*.sln.docstates
*.suo

# 4. Archivos de configuraciones de VS Code (por si acaso)
.vscode/

# 5. Archivos de publicación / Deploy
[Pp]ublish/
[Oo]ut/

# 6. Archivos temporales del Sistema Operativo
.DS_Store
Thumbs.db